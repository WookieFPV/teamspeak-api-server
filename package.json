{
  "name": "bun-hono-server",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "run": "bun run src/index.ts",
    "format": "bunx biome format --write .",
    "lint": "bunx biome lint --fix",
    "lint:CI": "bunx biome check",
    "check": "bunx biome check --fix"
  },
  "dependencies": {
    "hono": "4.12.9",
    "p-queue": "9.1.0",
    "ts3-nodejs-library": "3.5.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "latest",
    "lefthook": "2.1.4",
    "typescript": "5.9.3"
  }
}
